classDiagram
    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet)
        +list_pets()
        +get_all_tasks()
    }

    class Pet {
        +str name
        +str species
        +int age
        +List~Task~ tasks
        +add_task(task)
        +list_tasks()
        +get_task(description)
    }

    class Task {
        +str description
        +str due_time
        +date due_date
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +mark_complete()
        +next_occurrence()
        +display()
    }

    class Scheduler {
        +Owner owner
        +all_tasks()
        +sort_by_time(tasks)
        +sort_by_priority_then_time()
        +filter_tasks(pet_name, completed, priority)
        +detect_conflicts()
        +mark_task_complete(pet_name, description)
        +build_daily_plan(target_date)
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "1" Owner : organizes tasks for
